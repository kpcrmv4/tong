# ===== Supabase (ฐานข้อมูลคลาวด์หลัก + Realtime Broadcast) =====
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ===== Gemini (AI / OCR อ่านบัตรประชาชน) =====
# ค่าเหล่านี้เป็น "ค่าเริ่มต้นฝั่งเซิร์ฟเวอร์" เท่านั้น
# สามารถตั้ง/แทนที่ได้จากหน้าเว็บ: ตั้งค่า > AI / OCR (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# ===== Web Push (VAPID) — สำหรับแจ้งเตือน push บน PWA =====
# สร้างคู่กุญแจใหม่ได้ด้วย: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ===== เซิร์ฟเวอร์ =====
# PORT=3000
